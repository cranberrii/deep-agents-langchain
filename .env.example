# --- OpenAI-compatible endpoint -------------------------------------------
# OpenRouter example:
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-your-openrouter-key
MODEL_NAME=anthropic/claude-sonnet-4-6

# vLLM example (uncomment and adjust):
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=not-needed-but-required   # any non-empty string
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# --- Web search -----------------------------------------------------------
# Get a key at https://app.tavily.com
TAVILY_API_KEY=tvly-your-tavily-key

# --- Knowledge base (Milvus + embeddings, read by kb.py) ------------------
# Defaults shown; uncomment to override. Start Milvus with `docker compose up -d`.
# MILVUS_URI=http://localhost:19530
# MILVUS_COLLECTION=research_kb
# EMBED_MODEL=BAAI/bge-m3            # 1024-dim, multilingual; must match between ingest.py and the agent (re-ingest if changed)

# --- Optional tuning ------------------------------------------------------
# MAX_SEARCH_RESULTS=5
# MODEL_TEMPERATURE=0.0
